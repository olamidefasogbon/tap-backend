ENVIRONMENT=development
BASE_URL=http://localhost:3000

# Database (We will run Postgres via Docker later)
DATABASE_URL=postgresql+asyncpg://tap:secret@localhost:5432/tap_db

# Redis / Celery (For the 12-hour escrow)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Security
SECRET_KEY=super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Paystack (Put your real TEST keys here)
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_WEBHOOK_SECRET=whsec_your_secret
PAYSTACK_CORPORATE_ACCOUNT_CODE=ACC_test_code

# Meta WhatsApp
WHATSAPP_TOKEN=EAA_test_token
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_VERIFY_TOKEN=tap_verify_token

# FingerprintJS
FPJS_SECRET_API_KEY=fpjs_test_key

ESCROW_HOLD_HOURS=12
PLATFORM_FEE_PERCENT=4.0